{
  "name": "plataforma-turnos",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "dev": "pnpm --filter @turnos/web dev",
    "build": "pnpm --filter @turnos/shared build && pnpm --filter @turnos/web build",
    "lint": "pnpm --filter @turnos/shared lint && pnpm --filter @turnos/web lint",
    "typecheck": "pnpm --filter @turnos/shared typecheck && pnpm --filter @turnos/web typecheck",
    "test": "pnpm --filter @turnos/shared test && pnpm --filter @turnos/web test",
    "test:e2e": "pnpm --filter @turnos/web test:e2e",
    "check:client-secrets": "pnpm --filter @turnos/web check:client-secrets",
    "ci": "pnpm lint && pnpm typecheck && pnpm test && pnpm check:client-secrets && pnpm build"
  },
  "devDependencies": {
    "@playwright/test": "1.57.0",
    "@types/node": "22.13.14",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "10.4.21",
    "eslint": "9.39.1",
    "eslint-config-next": "16.2.9",
    "postcss": "8.5.6",
    "prettier": "3.6.2",
    "tailwindcss": "3.4.17",
    "typescript": "5.9.3",
    "typescript-eslint": "8.50.0",
    "vitest": "4.0.15"
  }
}
